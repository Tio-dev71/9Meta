{
  "name": "9meta",
  "version": "1.5.4",
  "description": "9Meta - Quản lý đa tài khoản Zalo, Messenger, Fanpage, Telegram, WhatsApp...",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.zalo.desktop",
    "productName": "9Meta",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.social-networking"
    },
    "dmg": {
      "title": "9Meta",
      "artifactName": "9Meta-${version}-mac.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "9Meta",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "custom_style.css",
      "icon.ico",
      "icon.png",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Tio-dev71",
        "repo": "Deplao-App"
      }
    ]
  },
  "keywords": [
    "9Meta",
    "multi-account",
    "desktop",
    "electron"
  ],
  "author": "Tiodev71",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}