generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum OrderPaymentStatus {
  pending
  paid
  failed
  expired
}

model User {
  id            String              @id @default(uuid())
  email         String              @unique
  passwordHash  String
  name          String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  subscriptions Subscription[]
  devices       AppDevice[]
  payments      PaymentEvent[]
  orders        SubscriptionOrder[]
}

model Plan {
  code               String              @id
  name               String
  monthlyPrice       Int
  yearlyPrice        Int
  maxAccountsPerApp  Int?
  unlimitedProxies   Boolean             @default(false)
  active             Boolean             @default(true)
  subscriptions      Subscription[]
  orders             SubscriptionOrder[]
}

model Subscription {
  id                  String             @id @default(uuid())
  userId              String
  planCode            String
  status              SubscriptionStatus
  cycle               String             @default("monthly")
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  provider            String
  providerCustomerId  String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planCode], references: [code])

  @@index([userId])
}

model SubscriptionOrder {
  id            String             @id @default(uuid())
  code          String             @unique
  userId        String
  planCode      String
  cycle         String
  amount        Int
  status        OrderPaymentStatus @default(pending)
  sepayTxnId    String?
  paidAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planCode], references: [code])

  @@index([userId])
  @@index([code])
  @@index([status])
}

model AppDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  appVersion String?
  os         String?
  lastSeenAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@index([userId])
}

model PaymentEvent {
  id        String   @id @default(uuid())
  userId    String?
  provider  String
  eventType String
  eventId   String
  payload   Json
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@unique([provider, eventId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
